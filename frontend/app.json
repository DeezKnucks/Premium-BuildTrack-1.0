{
  "expo": {
    "name": "BuildTrack",
    "slug": "buildtrack-premium",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "buildtrack",
    "userInterfaceStyle": "automatic",
    "owner": "deezknucks",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.deezknucks.buildtrack"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000"
      },
      "package": "com.deezknucks.buildtrack"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "fd684628-0da6-2811-4018-2fb36dfca480"
      }
    }
  }
}
